# --- Postgres ---
POSTGRES_USER=finagent
POSTGRES_PASSWORD=finagent_dev_pw
POSTGRES_DB=finagent
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://finagent:finagent_dev_pw@postgres:5432/finagent

# --- Redis (Celery broker + result backend) ---
REDIS_URL=redis://redis:6379/0

# --- SEC EDGAR ---
# REQUIRED by SEC: must include your name + email in User-Agent.
# https://www.sec.gov/os/accessing-edgar-data
SEC_USER_AGENT=FinancialAgent your_email@example.com

# --- Pipeline tuning ---
NEWS_INTERVAL_MINUTES=30
FILINGS_HOUR_UTC=22
COMPANIES_HOUR_UTC=20

# --- Flower (Celery monitoring UI) ---
FLOWER_PORT=5555

# --- Backend / Frontend (later phases) ---
BACKEND_PORT=8000
FRONTEND_PORT=3000
OLLAMA_BASE_URL=http://host.docker.internal:11434
LLM_MODEL=llama3.1:8b
