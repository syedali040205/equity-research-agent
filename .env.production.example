# ============================================================
# Copy these into Railway environment variables for each service
# ============================================================

# --- Database (get from neon.tech → New Project → Connection String) ---
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# --- Redis (get from upstash.com → Create Database → .env tab) ---
REDIS_URL=rediss://default:password@host.upstash.io:6379

# --- LLM (get from console.groq.com → API Keys) ---
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
LLM_MODEL=llama-3.1-8b-instant
LLM_QUALITY_MODEL=llama-3.3-70b-versatile

# --- SEC EDGAR (required by SEC, put your real name + email) ---
SEC_USER_AGENT=YourName your_email@gmail.com

# --- Worker schedule ---
NEWS_INTERVAL_MINUTES=30
FILINGS_HOUR_UTC=22
COMPANIES_HOUR_UTC=20

# --- Frontend URLs (set after you get your Railway backend URL) ---
# In Railway frontend service:
BACKEND_URL=https://your-backend.up.railway.app
# In Vercel (if using Vercel for frontend):
NEXT_PUBLIC_API_URL=https://your-backend.up.railway.app
